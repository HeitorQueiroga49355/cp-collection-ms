# === Django ===
DJANGO_SECRET_KEY=sua-chave-secreta-super-segura-aqui-mude-em-producao
# Deve ser igual ao DJANGO_SECRET_KEY do core em produção
CORE_JWT_SECRET_KEY=chave-do-core-em-producao
DEBUG=True

# === MongoDB ===
MONGO_INITDB_DATABASE=coleta_db
MONGO_USER=coleta_user
MONGO_PASSWORD=senha123
MONGO_HOST=localhost
MONGO_PORT=27017

# === RabbitMQ ===
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# === MinIO ===
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=coletas
MINIO_USE_HTTPS=False

# === Manutenção automatizada (mongo-maintenance) ===
# Quantos dias de registros manter nas coleções de log (audit_logs, etc.)
MONGO_RETENTION_DAYS=90
# Tamanho do lote de deleção (evita sobrecarga no banco durante limpeza)
MONGO_CLEANUP_BATCH=5000
# Coleções a serem limpas (separadas por espaço)
MONGO_CLEANUP_COLLECTIONS=audit_logs
